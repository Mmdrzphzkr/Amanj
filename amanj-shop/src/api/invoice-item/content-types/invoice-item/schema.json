{
  "kind": "collectionType",
  "collectionName": "invoice_items",
  "info": {
    "singularName": "invoice-item",
    "pluralName": "invoice-items",
    "displayName": "InvoiceItem"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoice": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::invoice.invoice",
      "inversedBy": "items"
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "default": 1,
      "min": 1
    },
    "unit_price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "total_price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },
    "description": {
      "type": "text",
      "required": true
    }
  }
}
