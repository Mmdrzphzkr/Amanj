{
  "kind": "collectionType",
  "collectionName": "service_invoices",
  "info": {
    "singularName": "service-invoice",
    "pluralName": "service-invoices",
    "displayName": "ServiceInvoice"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoice_number": {
      "type": "uid",
      "required": true
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "service_invoices"
    },
    "service_title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "statuses": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "draft",
        "pending",
        "completed",
        "cancelled"
      ]
    },
    "note": {
      "type": "text"
    }
  }
}
