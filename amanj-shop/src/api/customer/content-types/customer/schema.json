{
  "kind": "collectionType",
  "collectionName": "customers",
  "info": {
    "singularName": "customer",
    "pluralName": "customers",
    "displayName": "Customer"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "full_name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "company_name": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "notes": {
      "type": "text"
    },
    "invoices": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::invoice.invoice",
      "mappedBy": "customer"
    },
    "service_invoices": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-invoice.service-invoice",
      "mappedBy": "customer"
    }
  }
}
