{
  "kind": "collectionType",
  "collectionName": "repairs",
  "info": {
    "singularName": "repair",
    "pluralName": "repairs",
    "displayName": "Repair"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "repair_number": {
      "type": "uid",
      "required": true
    },
    "brand": {
      "type": "string",
      "required": true
    },
    "model": {
      "type": "string",
      "required": true
    },
    "serial_number": {
      "type": "string",
      "required": true
    },
    "problem": {
      "type": "text"
    },
    "received__date": {
      "type": "datetime",
      "required": false
    },
    "delivery_date": {
      "type": "datetime",
      "required": false
    },
    "statuses": {
      "type": "enumeration",
      "required": false,
      "default": "pending",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "delivered",
        "canceled"
      ]
    },
    "total_cost": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::repair-item.repair-item",
      "mappedBy": "repair"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "repairs"
    },
    "technician": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "date": {
      "type": "datetime"
    }
  }
}
