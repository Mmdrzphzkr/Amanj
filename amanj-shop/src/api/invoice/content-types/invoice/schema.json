{
  "kind": "collectionType",
  "collectionName": "invoices",
  "info": {
    "singularName": "invoice",
    "pluralName": "invoices",
    "displayName": "Invoice"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoice_number": {
      "type": "uid",
      "required": true
    },
    "statuses": {
      "type": "enumeration",
      "enum": [
        "نقدی",
        "کارت به کارت",
        "واریز بانکی",
        "چک",
        "اقساطی",
        "پرداخت آنلاین"
      ]
    },
    "issue_date": {
      "type": "datetime",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },
    "total_amount": {
      "type": "decimal",
      "required": true
    },
    "note": {
      "type": "string"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::invoice-item.invoice-item",
      "mappedBy": "invoice"
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "invoices"
    },
    "payment_method": {
      "type": "string"
    }
  }
}
