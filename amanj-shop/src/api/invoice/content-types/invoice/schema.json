{
  "kind": "collectionType",
  "collectionName": "invoices",
  "info": {
    "singularName": "invoice",
    "pluralName": "invoices",
    "displayName": "Invoice"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoice_number": {
      "type": "uid",
      "required": true
    },
    "statuses": {
      "type": "enumeration",
      "enum": [
        "نقدی",
        "کارت به کارت",
        "واریز بانکی",
        "چک",
        "اقساطی",
        "پرداخت آنلاین"
      ]
    },
    "issueDate": {
      "type": "datetime",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "totalDiscount": {
      "type": "decimal",
      "default": 0
    },
    "finalAmount": {
      "type": "decimal",
      "required": true
    },
    "note": {
      "type": "string"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::invoice-item.invoice-item",
      "mappedBy": "invoice"
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "customerPhone": {
      "type": "string",
      "required": true
    },
    "customerAddress": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "totalTax": {
      "type": "decimal",
      "default": 0
    },
    "commissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::commission.commission",
      "mappedBy": "invoice"
    }
  }
}
