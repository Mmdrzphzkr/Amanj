{
  "kind": "collectionType",
  "collectionName": "employees",
  "info": {
    "singularName": "employee",
    "pluralName": "employees",
    "displayName": "Employee"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "position": {
      "type": "string"
    },
    "baseSalary": {
      "type": "decimal",
      "required": false,
      "default": 0
    },
    "hire_date": {
      "type": "date"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "repairs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::repair.repair",
      "mappedBy": "technician"
    },
    "salaryType": {
      "type": "enumeration",
      "required": false,
      "default": "به ازای هر تعمیر",
      "enum": [
        "ماهانه",
        "درصدی",
        "به ازای هر تعمیر",
        "به ازای هر فاکتور",
        "ساعتی"
      ]
    },
    "commissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::commission.commission",
      "mappedBy": "employee"
    }
  }
}
